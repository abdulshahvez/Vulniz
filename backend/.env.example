# Server Configuration
PORT=3001
NODE_ENV=development

# AI Fix Suggestion Engine (Optional)
# Get a Gemini key for free at: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
OPENAI_API_KEY=sk-your-api-key-here

# Redis Configuration (optional — falls back to in-memory queue)
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Scan Configuration
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT_MS=30000

# Vulnerable API (for testing)
VULNERABLE_API_PORT=3002

# Domain Verification
REQUIRE_DOMAIN_VERIFICATION=false
